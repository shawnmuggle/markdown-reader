{
  "manifest_version": 3,
  "name": "Markdown Reader",
  "version": "1.0.0",
  "description": "把本地或在线的 .md / .markdown 文件渲染成 GitHub 风格的阅读视图，支持目录导航、代码高亮、深浅色切换、表格与 Mermaid 流程图。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "file:///*.md",
        "file:///*.markdown",
        "file:///*.mdown",
        "file:///*.mkd",
        "*://*/*.md",
        "*://*/*.markdown"
      ],
      "css": [
        "lib/github-markdown.css",
        "lib/github-markdown-theme-override.css",
        "lib/hljs-themes.css",
        "src/reader.css"
      ],
      "js": [
        "lib/marked.min.js",
        "lib/purify.min.js",
        "lib/highlight.min.js",
        "lib/mermaid.min.js",
        "src/i18n.js",
        "src/render.js",
        "src/toc.js",
        "src/theme.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
